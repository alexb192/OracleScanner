generator client {
    provider = "prisma-client-js"
    output   = "./generated/prisma"
}

datasource db {
    provider    = "postgresql"
}

enum Device {
    LAPTOP
    TABLET
}

model User {
    id        Int    @id @default(autoincrement())
    firstName String
    lastName  String
    items     Item[]
}

model Item {
    id             Int       @id @default(autoincrement())
    model          Device
    checkedOut     Boolean   @default(false)
    dateCheckedOut DateTime?
    checkedOutById Int?
    checkedOutBy   User?     @relation(fields: [checkedOutById], references: [id])
}
