generator client {
    provider = "prisma-client-js"
    output   = "./generated/prisma"
}

datasource db {
    provider    = "postgresql"
}

enum Device {
    LAPTOP
    TABLET
}

model Item {
    id          Int         @id @default(autoincrement())
    model       Device
    checkedOut  Boolean     @default(false)
    date        DateTime    @default(now())
}
